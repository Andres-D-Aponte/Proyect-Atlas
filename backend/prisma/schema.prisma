// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLATFORM_OWNER
  BUSINESS_ADMIN
  SUPERVISOR
  RECEPTIONIST_CASHIER
  PROFESSIONAL
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  TRIAL
}

/// Comportamiento al vencer una licencia (ver docs/01_Product_Requirements_Document.md sección 2.3).
enum LicenseExpirationBehavior {
  IMMEDIATE_READ_ONLY
  GRACE_PERIOD
  TEMPORARY_ACCESS
  FULL_BLOCK
}

enum PaymentMethod {
  CASH
  TRANSFER
  NEQUI
  DAVIPLATA
  CARD
  CREDIT
  OTHER
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

/// Tipo genérico de recurso físico reservable (ver PRD sección 3). El
/// inventario concreto (qué salas/sillas existen en cada sucursal) se
/// construirá en la Etapa 8 (Agenda), que es la primera que realmente
/// necesita reservarlos; por ahora un Service solo declara qué *tipo* de
/// recurso requiere, si aplica.
enum ResourceType {
  ROOM
  CHAIR
  CABIN
  MACHINE
  STRETCHER
}

/// Llaves primarias: numéricas seriales autoincrementales (`Int @id @default(autoincrement())`),
/// no UUID. Decisión explícita del dueño del producto.
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Nula para el Platform Owner (no pertenece a ninguna empresa).
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  refreshTokens     RefreshToken[]
  impersonationLogs ImpersonationLog[]

  @@map("users")
}

/// Token opaco (no JWT) del que solo se guarda su hash, para poder revocar
/// y rotar de verdad en cada uso (ver docs/02_Architecture.md sección 8).
model RefreshToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

/// Empresa cliente (tenant). Etapa 4 añade branding, zona horaria/moneda/
/// idioma y métodos de pago habilitados — configuración propia del negocio,
/// separada a propósito de la identidad mínima creada en la Etapa 3.
model Company {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logoUrl               String?
  primaryColor          String?
  /// Zona horaria por defecto; cada Branch puede sobreescribirla.
  timezone              String          @default("America/Bogota")
  currency              String          @default("COP")
  language              String          @default("es")
  /// Por defecto solo efectivo y transferencia (ver PRD sección 4.3).
  enabledPaymentMethods PaymentMethod[] @default([CASH, TRANSFER])

  /// Configuración de Clientes (ver PRD sección 4.6). Estos 3 solo controlan
  /// qué exige el formulario de alta de `Client`; `allowBookingWithoutClient`
  /// se guarda desde ya porque es parte del mismo grupo de configuración en
  /// el PRD, aunque solo lo hará cumplir la Agenda (Etapa 8).
  requireClientEmail        Boolean @default(false)
  requireClientDocument     Boolean @default(false)
  requireClientAddress      Boolean @default(false)
  allowBookingWithoutClient Boolean @default(true)

  users             User[]
  branches          Branch[]
  license           License?
  impersonationLogs ImpersonationLog[]
  serviceCategories ServiceCategory[]
  services          Service[]
  clients           Client[]

  @@map("companies")
}

/// Sucursal de una empresa. Horarios como Json simple (lista de
/// {dayOfWeek, opensAt, closesAt}) en vez de una tabla aparte — no aporta
/// valor normalizarlo más para el MVP (ver docs/01 sección 4.2/4.6).
model Branch {
  id           Int      @id @default(autoincrement())
  companyId    Int
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  address      String?
  /// Nula = usa la zona horaria de la empresa.
  timezone     String?
  openingHours Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@map("branches")
}

/// Nivel + módulos opcionales + límites de uso, configurables por el
/// Platform Owner (ver docs/01_Product_Requirements_Document.md sección 2.4).
/// Los límites son nullable = sin límite.
model Plan {
  id                       Int      @id @default(autoincrement())
  name                     String
  enabledModules           String[]
  maxBranches              Int?
  maxProfessionals         Int?
  maxUsers                 Int?
  maxAppointmentsPerMonth  Int?
  maxWhatsappConversations Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  licenses License[]

  @@map("plans")
}

/// Ciclo de facturación vigente de una empresa. Una empresa tiene, como
/// mucho, una licencia activa a la vez (sin historial de licencias pasadas
/// todavía — no hay necesidad de eso en el MVP, ver Project Charter: nada de
/// contabilidad completa).
model License {
  id                 Int                       @id @default(autoincrement())
  companyId          Int                       @unique
  company            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId             Int
  plan               Plan                      @relation(fields: [planId], references: [id])
  billingCycle       BillingCycle
  startDate          DateTime                  @default(now())
  endDate            DateTime
  expirationBehavior LicenseExpirationBehavior @default(IMMEDIATE_READ_ONLY)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@map("licenses")
}

/// Registro inmutable y obligatorio de cada vez que el Platform Owner entra
/// como Business Admin de una empresa (solo inserción, nunca update/delete).
/// Acotado a este caso de uso puntual; el sistema de auditoría genérico para
/// todos los módulos (shared/audit) sigue pendiente y se construirá cuando
/// haya más operaciones que auditar.
model ImpersonationLog {
  id              Int      @id @default(autoincrement())
  platformOwnerId Int
  platformOwner   User     @relation(fields: [platformOwnerId], references: [id])
  companyId       Int
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reason          String
  ipAddress       String?
  startedAt       DateTime @default(now())

  @@index([companyId])
  @@map("impersonation_logs")
}

/// Categoría de servicios, propia de cada empresa (nunca global). Dos
/// empresas distintas pueden usar el mismo nombre sin conflicto; dentro de
/// la misma empresa, no se permiten nombres repetidos.
model ServiceCategory {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

  @@unique([companyId, name])
  @@map("service_categories")
}

/// Servicio ofrecido por una empresa (nunca global, ver PRD sección 3).
/// `price` y `commissionValue` usan Float (no Decimal) a propósito: Atlas no
/// es un libro contable de precisión bancaria en el MVP (ver Project
/// Charter), y Decimal en Prisma se serializa como string en JSON, lo que
/// complica al frontend sin aportar nada real en esta etapa.
model Service {
  id         Int              @id @default(autoincrement())
  companyId  Int
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId Int?
  /// Nula si la categoría fue borrada; el servicio no desaparece con ella.
  category   ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  name        String
  description String?

  durationMinutes Int
  /// Tiempo de preparación/limpieza adicional después del servicio (ver PRD sección 4.2).
  bufferMinutes   Int @default(0)

  price Float

  commissionType  CommissionType @default(PERCENTAGE)
  /// Si `commissionType` es PERCENTAGE, valor entre 0 y 100; si es FIXED, monto en la moneda de la empresa.
  commissionValue Float          @default(0)

  requiresTwoProfessionals Boolean       @default(false)
  /// Tipo de recurso que exige este servicio (ver comentario del enum ResourceType); nulo = no requiere ninguno.
  resourceType             ResourceType?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([categoryId])
  @@map("services")
}

/// Cliente final del negocio (nunca global, ver PRD sección 3). Si la misma
/// persona visita otra empresa, es un `Client` completamente distinto aunque
/// comparta teléfono — el aislamiento por `companyId` ya garantiza esto.
model Client {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// Nombre y teléfono son el único mínimo real (ver backlog Épica 7); correo,
  /// documento y dirección son opcionales salvo que la empresa los exija
  /// (`Company.requireClientEmail/Document/Address`) — se valida en el
  /// servicio, no aquí, porque depende de configuración de otra tabla.
  name     String
  phone    String
  email    String?
  document String?
  address  String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timelineEvents ClientTimelineEvent[]

  @@index([companyId])
  @@map("clients")
}

enum ClientTimelineEventType {
  CREATED
  UPDATED
}

/// Línea de tiempo del cliente (ver backlog Épica 7). Por ahora solo registra
/// altas y ediciones de sus propios datos; los eventos de citas/ventas
/// (servicios recibidos, cancelaciones, inasistencias) los añadirán las
/// Etapas 8 (Agenda) y 10 (Ventas) insertando en esta misma tabla — no hace
/// falta ni se puede modelar su forma todavía (Regla de Oro del roadmap).
model ClientTimelineEvent {
  id          Int                     @id @default(autoincrement())
  clientId    Int
  client      Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        ClientTimelineEventType
  description String
  createdAt   DateTime                @default(now())

  @@index([clientId])
  @@map("client_timeline_events")
}
