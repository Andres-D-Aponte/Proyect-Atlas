// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLATFORM_OWNER
  BUSINESS_ADMIN
  SUPERVISOR
  RECEPTIONIST_CASHIER
  PROFESSIONAL
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  TRIAL
}

/// Comportamiento al vencer una licencia (ver docs/01_Product_Requirements_Document.md sección 2.3).
enum LicenseExpirationBehavior {
  IMMEDIATE_READ_ONLY
  GRACE_PERIOD
  TEMPORARY_ACCESS
  FULL_BLOCK
}

enum PaymentMethod {
  CASH
  TRANSFER
  NEQUI
  DAVIPLATA
  CARD
  CREDIT
  OTHER
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

/// Tipo genérico de recurso físico reservable (ver PRD sección 3). El
/// inventario concreto vive en el modelo `Resource` (Etapa 8); un `Service`
/// solo declara qué *tipo* de recurso requiere, si aplica.
enum ResourceType {
  ROOM
  CHAIR
  CABIN
  MACHINE
  STRETCHER
}

/// Bloqueo explícito sobre la agenda de un profesional (ver PRD sección 4.2):
/// "se crean bloqueos explícitos... en vez de eliminar horario".
enum ProfessionalBlockType {
  LUNCH
  TRAINING
  VACATION
  OTHER
}

/// Los 8 estados de una cita, tal cual los define el PRD sección 4.2 y el
/// backlog Épica 8. `WAITING` = cliente en sala de espera (ya llegó, no ha
/// sido atendido) — no confundir con la lista de espera (`Waitlist`), que es
/// un concepto totalmente distinto (clientes esperando que se libere un cupo).
enum AppointmentStatus {
  PENDING
  CONFIRMED
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum WaitlistStatus {
  WAITING
  OFFERED
  CONVERTED
  EXPIRED
  CANCELLED
}

/// Llaves primarias: numéricas seriales autoincrementales (`Int @id @default(autoincrement())`),
/// no UUID. Decisión explícita del dueño del producto.
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Nula para el Platform Owner (no pertenece a ninguna empresa).
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  refreshTokens     RefreshToken[]
  impersonationLogs ImpersonationLog[]
  /// Vínculo opcional Profesional↔Usuario, diferido desde la Etapa 5 hasta
  /// que existiera `Professional` (Etapa 8). Permite que un profesional
  /// inicie sesión sin recrear sus datos (ver backlog Épica 5).
  professional      Professional?

  @@map("users")
}

/// Token opaco (no JWT) del que solo se guarda su hash, para poder revocar
/// y rotar de verdad en cada uso (ver docs/02_Architecture.md sección 8).
model RefreshToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

/// Empresa cliente (tenant). Etapa 4 añade branding, zona horaria/moneda/
/// idioma y métodos de pago habilitados — configuración propia del negocio,
/// separada a propósito de la identidad mínima creada en la Etapa 3.
model Company {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logoUrl               String?
  primaryColor          String?
  /// Zona horaria por defecto; cada Branch puede sobreescribirla.
  timezone              String          @default("America/Bogota")
  currency              String          @default("COP")
  language              String          @default("es")
  /// Por defecto solo efectivo y transferencia (ver PRD sección 4.3).
  enabledPaymentMethods PaymentMethod[] @default([CASH, TRANSFER])

  /// Configuración de Clientes (ver PRD sección 4.6). Estos 3 solo controlan
  /// qué exige el formulario de alta de `Client`; `allowBookingWithoutClient`
  /// se guarda desde ya porque es parte del mismo grupo de configuración en
  /// el PRD, aunque solo lo hará cumplir la Agenda (Etapa 8).
  requireClientEmail        Boolean @default(false)
  requireClientDocument     Boolean @default(false)
  requireClientAddress      Boolean @default(false)
  allowBookingWithoutClient Boolean @default(true)

  /// Configuración de Agenda (ver PRD sección 4.2).
  /// Si es true, una cita nueva queda en PENDING y debe confirmarse
  /// manualmente; si es false, queda CONFIRMED de inmediato. Un solo campo
  /// cubre a propósito tanto "confirmación automática/manual" como "reserva
  /// inmediata o con aprobación" — el PRD los describe como dos preguntas
  /// separadas, pero para el MVP resuelven la misma decisión operativa.
  requireAppointmentApproval Boolean @default(false)
  /// Umbral de inasistencias de un cliente antes de mostrar una alerta al
  /// Business Admin (ver PRD sección 4.2, "Inasistencia").
  noShowAlertThreshold       Int     @default(3)
  /// A diferencia de las demás banderas de esta tabla, esta la define el
  /// Platform Owner por empresa, no el Business Admin — así lo dice el PRD
  /// sección 4.2 ("el Platform Owner define si una empresa puede o no
  /// permitirlo"). Por eso no está en `UpdateCompanySettingsDto`, sino en un
  /// endpoint aparte solo para Platform Owner.
  allowProfessionalChangeOnAppointment Boolean @default(true)

  users               User[]
  branches            Branch[]
  license             License?
  impersonationLogs   ImpersonationLog[]
  serviceCategories   ServiceCategory[]
  services            Service[]
  clients             Client[]
  professionals       Professional[]
  resources           Resource[]
  scheduleExceptions  ScheduleException[]
  appointments        Appointment[]
  waitlistEntries     Waitlist[]

  @@map("companies")
}

/// Sucursal de una empresa. Horarios como Json simple (lista de
/// {dayOfWeek, opensAt, closesAt}) en vez de una tabla aparte — no aporta
/// valor normalizarlo más para el MVP (ver docs/01 sección 4.2/4.6).
model Branch {
  id           Int      @id @default(autoincrement())
  companyId    Int
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  address      String?
  /// Nula = usa la zona horaria de la empresa.
  timezone     String?
  openingHours Json?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  professionalSchedules ProfessionalSchedule[]
  resources             Resource[]
  scheduleExceptions    ScheduleException[]
  appointments          Appointment[]
  waitlistEntries       Waitlist[]

  @@index([companyId])
  @@map("branches")
}

/// Nivel + módulos opcionales + límites de uso, configurables por el
/// Platform Owner (ver docs/01_Product_Requirements_Document.md sección 2.4).
/// Los límites son nullable = sin límite.
model Plan {
  id                       Int      @id @default(autoincrement())
  name                     String
  enabledModules           String[]
  maxBranches              Int?
  maxProfessionals         Int?
  maxUsers                 Int?
  maxAppointmentsPerMonth  Int?
  maxWhatsappConversations Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  licenses License[]

  @@map("plans")
}

/// Ciclo de facturación vigente de una empresa. Una empresa tiene, como
/// mucho, una licencia activa a la vez (sin historial de licencias pasadas
/// todavía — no hay necesidad de eso en el MVP, ver Project Charter: nada de
/// contabilidad completa).
model License {
  id                 Int                       @id @default(autoincrement())
  companyId          Int                       @unique
  company            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId             Int
  plan               Plan                      @relation(fields: [planId], references: [id])
  billingCycle       BillingCycle
  startDate          DateTime                  @default(now())
  endDate            DateTime
  expirationBehavior LicenseExpirationBehavior @default(IMMEDIATE_READ_ONLY)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@map("licenses")
}

/// Registro inmutable y obligatorio de cada vez que el Platform Owner entra
/// como Business Admin de una empresa (solo inserción, nunca update/delete).
/// Acotado a este caso de uso puntual; el sistema de auditoría genérico para
/// todos los módulos (shared/audit) sigue pendiente y se construirá cuando
/// haya más operaciones que auditar.
model ImpersonationLog {
  id              Int      @id @default(autoincrement())
  platformOwnerId Int
  platformOwner   User     @relation(fields: [platformOwnerId], references: [id])
  companyId       Int
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reason          String
  ipAddress       String?
  startedAt       DateTime @default(now())

  @@index([companyId])
  @@map("impersonation_logs")
}

/// Categoría de servicios, propia de cada empresa (nunca global). Dos
/// empresas distintas pueden usar el mismo nombre sin conflicto; dentro de
/// la misma empresa, no se permiten nombres repetidos.
model ServiceCategory {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

  @@unique([companyId, name])
  @@map("service_categories")
}

/// Servicio ofrecido por una empresa (nunca global, ver PRD sección 3).
/// `price` y `commissionValue` usan Float (no Decimal) a propósito: Atlas no
/// es un libro contable de precisión bancaria en el MVP (ver Project
/// Charter), y Decimal en Prisma se serializa como string en JSON, lo que
/// complica al frontend sin aportar nada real en esta etapa.
model Service {
  id         Int              @id @default(autoincrement())
  companyId  Int
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId Int?
  /// Nula si la categoría fue borrada; el servicio no desaparece con ella.
  category   ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  name        String
  description String?

  durationMinutes Int
  /// Tiempo de preparación/limpieza adicional después del servicio (ver PRD sección 4.2).
  bufferMinutes   Int @default(0)

  price Float

  commissionType  CommissionType @default(PERCENTAGE)
  /// Si `commissionType` es PERCENTAGE, valor entre 0 y 100; si es FIXED, monto en la moneda de la empresa.
  commissionValue Float          @default(0)

  requiresTwoProfessionals Boolean       @default(false)
  /// Tipo de recurso que exige este servicio (ver comentario del enum ResourceType); nulo = no requiere ninguno.
  resourceType             ResourceType?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments    Appointment[]
  waitlistEntries Waitlist[]

  @@index([companyId])
  @@index([categoryId])
  @@map("services")
}

/// Cliente final del negocio (nunca global, ver PRD sección 3). Si la misma
/// persona visita otra empresa, es un `Client` completamente distinto aunque
/// comparta teléfono — el aislamiento por `companyId` ya garantiza esto.
model Client {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  /// Nombre y teléfono son el único mínimo real (ver backlog Épica 7); correo,
  /// documento y dirección son opcionales salvo que la empresa los exija
  /// (`Company.requireClientEmail/Document/Address`) — se valida en el
  /// servicio, no aquí, porque depende de configuración de otra tabla.
  name     String
  phone    String
  email    String?
  document String?
  address  String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Se incrementa cada vez que una cita de este cliente se marca NO_SHOW
  /// (ver PRD sección 4.2, "Inasistencia"). Comparado contra
  /// `Company.noShowAlertThreshold` para mostrar una alerta.
  noShowCount Int @default(0)

  timelineEvents  ClientTimelineEvent[]
  appointments    Appointment[]
  waitlistEntries Waitlist[]

  @@index([companyId])
  @@map("clients")
}

enum ClientTimelineEventType {
  CREATED
  UPDATED
}

/// Línea de tiempo del cliente (ver backlog Épica 7). Por ahora solo registra
/// altas y ediciones de sus propios datos; los eventos de citas/ventas
/// (servicios recibidos, cancelaciones, inasistencias) los añadirán las
/// Etapas 8 (Agenda) y 10 (Ventas) insertando en esta misma tabla — no hace
/// falta ni se puede modelar su forma todavía (Regla de Oro del roadmap).
model ClientTimelineEvent {
  id          Int                     @id @default(autoincrement())
  clientId    Int
  client      Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        ClientTimelineEventType
  description String
  createdAt   DateTime                @default(now())

  @@index([clientId])
  @@map("client_timeline_events")
}

/// Persona que presta un servicio (ver PRD sección 3). Puede existir sin
/// `User` (gestionado solo por recepción) o vincularse a uno para poder
/// iniciar sesión — vínculo diferido desde la Etapa 5 hasta ahora.
model Professional {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    Int?     @unique
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules          ProfessionalSchedule[]
  blocks             ProfessionalBlock[]
  appointments       Appointment[] @relation("PrimaryProfessional")
  secondAppointments Appointment[] @relation("SecondProfessional")
  waitlistEntries    Waitlist[]

  @@index([companyId])
  @@map("professionals")
}

/// Jornada laboral recurrente de un profesional: puede trabajar horarios
/// distintos por sucursal y día (ver PRD sección 4.2 y backlog Épica 8). El
/// "botón de jornada predefinida" que menciona el PRD es un atajo del
/// frontend que termina generando filas normales de esta tabla — no hace
/// falta modelarlo aparte.
model ProfessionalSchedule {
  id             Int          @id @default(autoincrement())
  professionalId Int
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  branchId       Int
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  /// 0 = domingo … 6 = sábado (mismo criterio que `Branch.openingHours`).
  dayOfWeek      Int
  startsAt       String
  endsAt         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([professionalId])
  @@index([branchId])
  @@map("professional_schedules")
}

/// Bloqueo explícito sobre la agenda de un profesional (almuerzo,
/// capacitación, vacaciones, otro) — nunca se "borra" horario, se bloquea
/// (ver PRD sección 4.2). Una vacación es solo un bloqueo cuyo rango cubre
/// varios días; no necesita lógica especial.
model ProfessionalBlock {
  id             Int                   @id @default(autoincrement())
  professionalId Int
  professional   Professional          @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  type           ProfessionalBlockType
  startAt        DateTime
  endAt          DateTime
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([professionalId])
  @@map("professional_blocks")
}

/// Instancia concreta de un recurso reservable en una sucursal (ver PRD
/// sección 3/4.4). Se construye hasta esta etapa porque es la primera que
/// realmente necesita reservarlos contra un horario (ver docs/modules/06).
model Resource {
  id        Int          @id @default(autoincrement())
  companyId Int
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId  Int
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  type      ResourceType
  name      String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  appointments Appointment[]

  @@index([companyId])
  @@index([branchId])
  @@map("resources")
}

/// Calendario de excepciones/festivos (ver PRD sección 4.2): un día cerrado,
/// ya sea de una sucursal puntual (`branchId` presente) o de toda la
/// empresa (`branchId` nulo). Solo modela cierres de día completo — el PRD
/// no pide horarios parciales de festivo para el MVP.
model ScheduleException {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  reason    String
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([branchId])
  @@map("schedule_exceptions")
}

/// La cita: el corazón del sistema (ver PRD sección 4.2 y backlog Épica 8).
/// `endAt` es el fin del servicio (lo que ve el staff); `blockedUntil` es
/// `endAt` + el buffer del servicio en el momento de crear la cita — se
/// guarda aparte para que el chequeo de solapamiento sea una comparación de
/// rangos simple en la base de datos, sin tener que calcularlo en memoria
/// contra el buffer actual del servicio (que además pudo cambiar después).
model Appointment {
  id        Int     @id @default(autoincrement())
  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId  Int
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  /// Nulo si la empresa permite reservar sin cliente registrado
  /// (`Company.allowBookingWithoutClient`).
  clientId Int?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id])

  professionalId Int
  professional   Professional @relation("PrimaryProfessional", fields: [professionalId], references: [id])
  /// Solo si `Service.requiresTwoProfessionals`.
  secondProfessionalId Int?
  secondProfessional   Professional? @relation("SecondProfessional", fields: [secondProfessionalId], references: [id])
  /// Solo si `Service.resourceType` no es nulo.
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id])

  startAt      DateTime
  endAt        DateTime
  blockedUntil DateTime

  status AppointmentStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  historyEvents AppointmentHistoryEvent[]

  @@index([companyId])
  @@index([branchId])
  @@index([professionalId])
  @@index([clientId])
  @@map("appointments")
}

/// Historial de una cita (ver backlog Épica 8: "el cambio de estado queda
/// registrado en el historial de la cita con quién lo hizo"). Mismo patrón
/// que `ClientTimelineEvent` (Etapa 7): descripción ya armada en español,
/// generada por el servicio, no un enum de tipos de evento.
model AppointmentHistoryEvent {
  id            Int         @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  description   String
  createdAt     DateTime    @default(now())

  @@index([appointmentId])
  @@map("appointment_history_events")
}

/// Lista de espera (ver PRD sección 4.2 y backlog Épica 8): si no hay cupo,
/// el cliente queda aquí; al cancelarse una cita compatible, el primero en
/// la lista pasa a OFFERED. El envío real de la oferta al cliente (WhatsApp)
/// depende de la Etapa 11, que todavía no existe — por ahora la oferta
/// queda visible para que el staff contacte manualmente (ver docs/modules/08).
model Waitlist {
  id        Int            @id @default(autoincrement())
  companyId Int
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId  Int
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clientId  Int
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId Int
  service   Service        @relation(fields: [serviceId], references: [id])
  /// Nulo = cualquier profesional sirve.
  professionalId Int?
  professional   Professional? @relation(fields: [professionalId], references: [id])

  status    WaitlistStatus @default(WAITING)
  offeredAt DateTime?
  createdAt DateTime       @default(now())

  @@index([companyId])
  @@index([branchId])
  @@map("waitlist_entries")
}
