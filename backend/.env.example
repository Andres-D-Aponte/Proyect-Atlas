# Copiar como .env y ajustar valores locales. Nunca commitear el .env real.
NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://atlas:atlas_dev_password@localhost:5433/atlas?schema=public"

JWT_ACCESS_SECRET=replace-with-a-random-string-of-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# Solo para `npm run db:seed` en desarrollo.
SEED_PLATFORM_OWNER_EMAIL=owner@atlas.dev
SEED_PLATFORM_OWNER_PASSWORD=ChangeMe123!
